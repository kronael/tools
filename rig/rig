#!/bin/bash

# ── Shared helpers ──────────────────────────────────────────────────

dedupe(){ awk '!seen[$0]++'; }
strip_origin(){ sed 's|^origin/||'; }

recent(){
    git reflog --format='%gs' --all \
        | sed -n 's/checkout: moving from .* to //p' \
        | dedupe \
        | head -50
}

all(){
    git for-each-ref --sort=-committerdate \
        --format='%(refname:short)' refs/heads refs/remotes
}

branches(){ { recent; all; } | strip_origin | dedupe; }

clean_branch(){
    echo "$1" | sed -E 's#^(origin/|refs/|heads/|remotes/|tags/)+##; s/[~^].*//'
}

get_current_branch(){
    local branch
    branch=$(git symbolic-ref --short HEAD 2>/dev/null)
    [[ -n "$branch" ]] && { clean_branch "$branch"; return; }
    # detached HEAD — walk first-parent ancestry for a remote branch
    local c="HEAD"
    while git rev-parse --verify "$c" &>/dev/null; do
        branch=$(git for-each-ref --points-at "$c" --format='%(refname:short)' \
            refs/remotes/ | grep '/' | grep -v '/HEAD$' | head -1)
        [[ -n "$branch" ]] && { clean_branch "$branch"; return; }
        # merge commit = ambiguous ancestry, bail
        [[ $(git rev-parse --verify "$c^2" 2>/dev/null) ]] && break
        c="$c^"
    done
    echo "error: no branch found" >&2
    return 1
}

is_commit_not_branch(){
    git rev-parse --verify "$1^{commit}" &>/dev/null \
        && ! git show-ref --verify --quiet "refs/heads/$1" \
        && ! git show-ref --verify --quiet "refs/remotes/origin/$1"
}

pick_branch(){
    local args=(--height=40%)
    [[ "$1" != "?" ]] && args+=(--select-1 --exit-0 --query="$1")
    branches | fzf "${args[@]}"
}

# ── Subcommands ─────────────────────────────────────────────────────

BRANCH_HELP="Usage: rig %s [-z] [-n] [pattern]
Flags: -z offline (no fetch), -n dry-run, ? force fzf"

cmd_branch_op(){
    local op=$1; shift

    # Parse flags
    local fetch=1
    while [[ "${1:-}" =~ ^- ]]; do
        case "$1" in
            -z|--offline) fetch=; shift ;;
            -n) local dryrun=1; shift ;;
            -h|--help) printf "$BRANCH_HELP\n" "$op"; exit 0 ;;
            *) echo "error: unknown flag: $1"; exit 1 ;;
        esac
    done

    # Fetch before selection so fzf shows current branches
    [[ $fetch ]] && git fetch

    # Select branch
    local pattern="${1:-}"
    pattern="${pattern#origin/}"
    if [[ -z "$pattern" && ("$op" == "rebase" || "$op" == "merge") ]]; then
        pattern=$(get_current_branch 2>/dev/null || true)
    fi
    local branch=$(pick_branch "$pattern")
    [[ -z "$branch" ]] && {
        echo "error: no branch selected"; exit 1
    }

    # Execute
    if [[ ${dryrun:-} ]]; then
        echo "origin/$branch"
    else
        case "$op" in
            checkout) git checkout "origin/$branch" ;;
            rebase)   git rebase -i "origin/$branch" ;;
            merge)    git merge "origin/$branch" ;;
        esac
    fi
}

cmd_push(){
    # Parse flags
    while [[ "${1:-}" =~ ^- ]]; do
        case "$1" in
            -n) local dryrun=1; shift ;;
            -h|--help)
                cat <<EOF
Usage: rig push [-n] [branch[:commit]] [git-push-flags]
Flags: -n dry-run, ? interactive selection
EOF
                exit 0 ;;
            *) break ;;
        esac
    done

    # Select branch and commit
    local branch commit="HEAD"
    case "${1:-}" in
        "")  branch=$(get_current_branch 2>/dev/null) || branch=$(pick_branch "?")
             [[ -z "$branch" ]] && exit 1 ;;
        "?") branch=$(pick_branch "?")
             [[ -z "$branch" ]] && exit 1; shift ;;
        *:*) branch=$(clean_branch "${1%:*}")
             commit=${1#*:}; shift ;;
        *)   if is_commit_not_branch "$1"; then
                 echo "warn: '$1' looks like a commit, not a branch"
                 echo "      use branch:commit syntax"
                 branch=$(get_current_branch 2>/dev/null)
             else
                 branch=$(clean_branch "$1")
             fi; shift ;;
    esac

    # Validate
    [[ -z "$branch" ]] && {
        echo "error: could not determine branch"
        echo "usage: rig push [branch] or rig push ?"
        exit 1
    }

    # Execute
    if [[ ${dryrun:-} ]]; then
        echo "git push origin $@ $commit:refs/heads/$branch" --tags
    else
        git push origin "$@" "$commit:refs/heads/$branch" --tags
    fi
}

# ── Fixup squash ────────────────────────────────────────────────────

cmd_fixup(){
    local fixup_pat='^fixup[[:space:]:!;]'

    # Find oldest fixup commit to determine rebase base
    local oldest
    oldest=$(git log --format="%H %s" | \
        awk -v p="$fixup_pat" '$0 ~ p {last=$1} END{print last}')
    [[ -z "$oldest" ]] && { echo "no fixup commits"; return 0; }

    # Sequence editor: mark fixup-pattern picks as fixup
    local seq_ed
    seq_ed=$(mktemp /tmp/rig-fixup-XXXXX.sh)
    cat > "$seq_ed" <<'EOF'
#!/bin/bash
todo=$1
tmp=$todo.tmp
while IFS= read -r line; do
    [[ "$line" =~ ^pick[[:space:]]+([a-f0-9]+) ]] || { echo "$line"; continue; }
    msg=$(git log -1 --format='%s' "${BASH_REMATCH[1]}" 2>/dev/null)
    if [[ "$msg" =~ ^fixup[[:space:]:!;] ]]; then
        echo "${line/pick/fixup}"
    else
        echo "$line"
    fi
done < "$todo" > "$tmp" && mv "$tmp" "$todo"
EOF
    chmod +x "$seq_ed"
    GIT_SEQUENCE_EDITOR="$seq_ed" git rebase -i "$oldest^"
    rm -f "$seq_ed"
}

# ── Install ──────────────────────────────────────────────────────────

cmd_install(){
    local dir=$(dirname "$(readlink -f "$0")")
    local symlinks=(rco rip rir rim)
    for s in "${symlinks[@]}"; do
        ln -sf rig "$dir/$s"
        echo "  $dir/$s -> rig"
    done
    echo "installed ${#symlinks[@]} symlinks"
}

# ── Dispatch ────────────────────────────────────────────────────────

usage(){
    cat <<EOF
rig - ripgit: git tools

  rig co [pattern]   Checkout origin (rco)
  rig p [branch]     Push to origin (rip)
  rig r [pattern]    Rebase -i origin (rir)
  rig m [pattern]    Merge origin (rim)
  rig sq             Squash fixup commits
  rig install        Create symlinks

Flags: -z offline, -n dry-run, ? force fzf
EOF
    exit 1
}

dispatch(){
    case "$1" in
        co|checkout|rco) shift; cmd_branch_op checkout "$@" ;;
        p|push|rip)      shift; cmd_push "$@" ;;
        r|rebase|rir)    shift; cmd_branch_op rebase "$@" ;;
        m|merge|rim)     shift; cmd_branch_op merge "$@" ;;
        sq|fixup)        shift; cmd_fixup "$@" ;;
        install)         cmd_install ;;
        -h|--help|help|"") usage ;;
        *)  echo "error: unknown command: $1"; usage ;;
    esac
}

name=$(basename "$0")
if [[ "$name" != "rig" ]]; then
    dispatch "$name" "$@"
else
    dispatch "${1:-}" "${@:2}"
fi
