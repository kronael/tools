{
  "permissions": {
    "allow": [
      "Task(*)",
      "Skill(*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git add [^-]*)",
      "Bash(git commit*)",
      "Bash(gh pr comment*)",
      "Bash(gh api repos/*/pulls/*/reviews*)",
      "Bash(gh api repos/*/pulls/*/comments*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(chmod 777*)",
      "Bash(git push*)",
      "Bash(git pull*)",
      "Bash(ssh *)",
      "Bash(rsync *)",
      "Bash(gh pr create*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr review --approve*)",
      "Bash(gh release create*)",
      "Bash(gh repo create*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/local.py",
            "timeout": 500
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/prompt_nudge.py",
            "timeout": 500
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/pretool_nudge.py",
            "timeout": 500
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/post_tool_nudge.sh",
            "timeout": 1000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/stop.py",
            "timeout": 1000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/local.py",
            "timeout": 500
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/reclaude.py",
            "timeout": 500
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "git",
      "uv"
    ]
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "promptSuggestionEnabled": false,
  "spinnerTipsEnabled": false,
  "env": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0"
  },
  "outputStyle": "80% caveman",
  "cleanupPeriodDays": 3650000
}
