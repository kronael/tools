---
name: Lint

on:
    pull_request:
        branches: [master]
    workflow_dispatch:

jobs:
    pre-commit:
        runs-on: ubuntu-latest
        timeout-minutes: 5
        steps:
            - uses: actions/checkout@v4
              with:
                  fetch-depth: 0
            - uses: actions/setup-python@v5
              with:
                  python-version: '3.12'
            - uses: pre-commit/action@v3.0.0
              with:
                  extra_args: >-
                      --from-ref ${{ github.event.pull_request.base.sha }}
                      --to-ref ${{ github.event.pull_request.head.sha }}
